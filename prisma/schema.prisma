generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PublishSettings {
  id              Int      @id @default(autoincrement())
  section         String   @unique
  strategy        String   @default("manual")
  dailyLimit      Int      @default(1)
  scheduleEnabled Boolean  @default(false)
  scheduleTime    String   @default("08:00")
  randomEnabled   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RandomPublishLog {
  id             Int      @id @default(autoincrement())
  section        String
  date           DateTime
  publishedCount Int
  createdAt      DateTime @default(now())
  
  @@unique([section, date])
}

model Blog {
  id              String   @id @default(cuid())
  title           String
  content         String
  category        String
  status          String   @default("pending")
  date            DateTime @default(now())
  publishedAt     DateTime?
  publishAt       DateTime?
  similarTitles   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("blogs")
}

model QA {
  id              String   @id @default(cuid())
  title           String
  content         String
  category        String
  status          String   @default("pending")
  date            DateTime @default(now())
  publishedAt     DateTime?
  publishAt       DateTime?
  similarTitles   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("qas")
}

model Cases {
  id              String   @id @default(cuid())
  title           String
  content         String
  category        String
  status          String   @default("pending")
  date            DateTime @default(now())
  publishedAt     DateTime?
  publishAt       DateTime?
  similarTitles   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("cases")
}